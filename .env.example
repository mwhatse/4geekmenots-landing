# Full URL for the RJ Creative Group website.
VITE_RJ_SITE_URL=

# Server-only CRM connection used by api/quote-request.js.
RJ_SUPABASE_URL=
RJ_SUPABASE_ANON_KEY=

# Server-only Printify catalog connection used by api/products.js.
# Never prefix these variables with VITE_.
PRINTIFY_API_TOKEN=
# Optional override. The Etsy shop is discovered automatically when this is blank.
PRINTIFY_SHOP_ID=
